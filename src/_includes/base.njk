<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}Heifer Society</title>
  <meta name="description" content="{% if excerpt %}{{ excerpt }}{% else %}Stop shrinking. Learn how to take up space.{% endif %}">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="bg-bone min-h-screen">
  <div class="grain-overlay"></div>
  
  <nav class="fixed top-0 left-0 w-full z-50 px-6 md:px-[6vw] py-6 flex justify-between items-center bg-bone/80 backdrop-blur-sm">
    <a href="/" class="font-serif text-lg tracking-[0.3em] uppercase text-charcoal hover:text-oxblood transition-colors">
      Heifer Society
    </a>
    
    <div class="hidden md:flex items-center gap-8">
      <a href="/#breaking-point" class="text-micro text-charcoal/70 hover:text-charcoal link-underline transition-colors">About</a>
      <a href="/essays/" class="text-micro text-charcoal/70 hover:text-charcoal link-underline transition-colors">Journal</a>
      <a href="/manifesto/" class="text-micro text-charcoal/70 hover:text-charcoal link-underline transition-colors">Manifesto</a>
      <a href="/contact/" class="text-micro text-charcoal/70 hover:text-charcoal link-underline transition-colors">Contact</a>
      <a href="/merch/" class="text-micro text-charcoal/70 hover:text-charcoal link-underline transition-colors">Shop</a>
      <a href="/work-with-me/" class="text-micro text-charcoal/70 hover:text-charcoal link-underline transition-colors">Work With Me</a>
    </div>
  </nav>

  <main class="pt-16">
    {{ content | safe }}
  </main>

  <footer class="relative bg-charcoal">
    <div class="flex justify-center pt-12">
      <svg viewBox="0 0 200 30" class="w-[200px] h-[30px]">
        <path d="M10,25 Q100,5 190,25" fill="none" stroke="#C9A961" stroke-width="1.5" opacity="0.7"/>
      </svg>
    </div>
    
    <div class="py-16 md:py-20 px-6">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-wrap justify-center gap-6 md:gap-10 mb-12">
          <a href="/#breaking-point" class="text-micro text-bone/60 hover:text-bone transition-colors">About</a>
          <a href="/essays/" class="text-micro text-bone/60 hover:text-bone transition-colors">Journal</a>
          <a href="/manifesto/" class="text-micro text-bone/60 hover:text-bone transition-colors">Manifesto</a>
          <a href="/contact/" class="text-micro text-bone/60 hover:text-bone transition-colors">Contact</a>
          <a href="/merch/" class="text-micro text-bone/60 hover:text-bone transition-colors">Shop</a>
          <a href="/work-with-me/" class="text-micro text-bone/60 hover:text-bone transition-colors">Work With Me</a>
        </div>
        
        <div class="text-center">
          <p class="font-serif text-xl md:text-2xl text-bone/50 italic">
            "Handle your own. With class."
          </p>
        </div>
        
        <div class="mt-12 pt-8 border-t border-bone/10 text-center">
          <p class="font-mono text-xs text-bone/40 tracking-wider">
            © 2025 Heifer Society. All rights reserved.
          </p>
        </div>
      </div>
    </div>
  </footer>
</body>
</html>
